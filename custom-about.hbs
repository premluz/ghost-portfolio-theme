{{!< default}}
<article class="page">
  {{#if @page.show_title_and_feature_image}}
    <header class="page-header">
      <div class="container">
        <h1 class="page-title">About {{@site.title}}</h1>
        {{#if custom_excerpt}}
        <p class="post-excerpt">{{custom_excerpt}}</p>
       {{/if}}
      </div>
    {{#if feature_image}}
      <figure class="post-image">
        <img src="{{feature_image}}" alt="{{title}}" loading="lazy">
      </figure>
    {{/if}}
    </header>
  {{/if}}

    {{> about}}

    {{> personal}}

</article>


