{{!-- Animate the post-page nav collapse — but only on a genuine arrival
      from a non-post page. html.nav-hop (default.hbs head script) means
      we hopped here from another post via prev/next, which was already
      collapsed — nothing to animate, the CSS collapses it instantly pre-
      paint instead (see main.css "POST PAGE NAV"). Otherwise the nav
      renders expanded for a couple of frames on purpose (double rAF, so
      the browser has actually painted that expanded state at least once
      — a single rAF isn't reliably enough), then this adds the class that
      triggers the collapse transition, and a matching class afterward
      that removes .logoandnavwrapper from layout once the animation has
      actually finished (can't be part of the transition itself — display
      isn't animatable — doing it early would make the collapse look like
      it snaps partway through instead of shrinking smoothly). --}}
<script>
  (function () {
    if (document.documentElement.classList.contains('nav-hop')) return;
    if (!document.body.classList.contains('post-template')) return;
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        document.body.classList.add('nav-collapsing');
        setTimeout(function () {
          document.body.classList.add('nav-collapsed-settled');
        }, 450);
      });
    });
  })();
</script>
