<section class="posts-tabs-section" data-card-animation="slide-left" id="work" data-page-width="{{@custom.page_width}}" data-active-tab="featured">

  {{!-- Glass switch component (independent, syncs to tab state) --}}



  <div class="posts-tabs-wrapper">
    {{!-- Tabs header (hidden — switch component used instead) --}}
    <div class="posts-tabs-header" style="display:none">
      <div class="posts-tabs-buttons">
        <button class="posts-tab posts-tab-featured active h2" data-tab="featured" data-animate="word">Work</button>
        <button class="posts-tab posts-tab-experimental h2ac" data-tab="experimental" data-animate="word">Lab</button>
      </div>
      <p class="posts-tabs-description">Real products, real constraints, real impact.</p>
    </div>


    {{!-- Tabs content --}}
    <div class="posts-tabs-container">
      {{!-- Featured tab --}}
      <div class="posts-tabs-content posts-tabs-content-featured active" data-tab="featured">
        <div class="posts-grid" data-posts-layout="{{@custom.posts_layout}}">
          <div class="container">
            <div id="work-cards"></div>
            <div class="carousel-track">
              {{#get "posts" filter="featured:true+tag:hash-work+tag:featured" limit="100" include="tags,authors"}}
                {{#foreach posts}}
                  {{> post-card}}
                {{/foreach}}
              {{/get}}
            </div>
          </div>
          <div class="carousel-controls">
            <button class="carousel-arrow carousel-prev" aria-label="Previous post" type="button">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
              </svg>
            </button>
            <button class="carousel-arrow carousel-next" aria-label="Next post" type="button">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      {{!-- Experimental tab --}}
      <div class="posts-tabs-content posts-tabs-content-experimental" data-tab="experimental">
        <div class="posts-grid" data-posts-layout="{{@custom.posts_layout}}">
          <div class="container">
            <div id="work-cards"></div>
            <div class="carousel-track">
              {{#get "posts" filter="featured:true+tag:hash-work+tag:experimental" limit="100" include="tags,authors"}}
                {{#foreach posts}}
                  {{> post-card}}
                {{/foreach}}
              {{/get}}
            </div>
          </div>
          <div class="carousel-controls">
            <button class="carousel-arrow carousel-prev" aria-label="Previous post" type="button">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
              </svg>
            </button>
            <button class="carousel-arrow carousel-next" aria-label="Next post" type="button">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
