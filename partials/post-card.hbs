<article class="post-card" data-post-url="{{url}}"{{#if tags}} data-tag-slugs="{{#foreach tags}}{{slug}} {{/foreach}}"{{/if}}{{#if custom.gradientCss}} data-gradient-css="{{custom.gradientCss}}"{{/if}}{{#if custom.cardId}} data-cardid="{{custom.cardId}}"{{else}} data-cardid="{{slug}}"{{/if}}>
  <a href="{{url}}" class="post-card-link" data-transition>
    {{!-- Inner wrapper that scales on hover, while link stays stable --}}
    <div class="post-card-inner">


      <div class="post-card-content" data-card-reveal="default" data-item-index="1">
        <h3 class="post-card-title" data-default-title="{{longTitle}}">{{longTitle}}</h3>
        {{!-- Project client name --}}
      <!--<p class="text-eyebrow">Key contributions</p>-->
        {{!-- Card description (from projectMeta) - only shows as separate section before card --}}
      <!-- <div class="post-card-description"></div>-->

        <div class="post-card-meta">
          <!-- <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM DD, YYYY"}}</time>-->
          {{!-- Keywords pills (from projectMeta cardKeywords) --}}
         <div class="post-card-keywords"></div>
          <!--{{#if @custom.show_reading_time}}
            {{#if reading_time}}
              <span class="reading-time">{{reading_time}}</span>
            {{/if}}
          {{/if}}-->
        </div>
        {{!-- Project result --}}
       <!--<div class="post-card-result"></div>-->

        {{#if custom_excerpt}}
       <!--  <p class="post-card-excerpt">{{custom_excerpt}}</p>-->
        {{else}}
      <!--    <p class="post-card-excerpt">{{excerpt words="30"}}</p>-->
        {{/if}}

        {{!-- Testimonial quote (from projectMeta) --}}
        <p class="post-card-testimonial serif"></p>
        <p class="post-card-endorser"></p>

      </div>
            {{#if feature_image}}
        <div class="post-card-image" data-card-reveal="default" data-item-index="0">
          {{!-- loading="lazy" was unconditional, including on the first
                card — always above the fold, so deferring it just delays
                the network fetch with no benefit. posts-tabs.hbs now
                passes first=@first through the {{#foreach}}. --}}
          {{!-- data-skip-reveal: .post-card-image is no longer part of
                card-scroll-reveal.js's system at all (page-level entrance
                only — see post-card-grid.css), but the generic per-<img>
                reveal (same file) has no exclusion for this container and
                would otherwise still fade this image in independently,
                same bug as the container used to have. --}}
          {{!-- Shimmer placeholder shown until post-and-cards.js's
                fetchCardMeta knows whether this post has a video — the
                image below stays opacity:0 (see post-card-grid.css) and
                is only faded in if it turns out there's no video, so a
                card never shows a raw image that a video then covers a
                beat later. --}}
          <div class="card-media-skeleton"></div>
          <img src="{{feature_image}}" alt="{{title}}" {{#unless first}}loading="lazy" {{/unless}}data-skip-reveal>
        </div>
      {{/if}}
    </div>
  </a>
</article>
