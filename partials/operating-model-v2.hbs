        <p class="om-description">Building products people understand, trust and adopt.</p>
      </div>

      <div class="om-carousel">
        <div class="om-carousel-track">
          {{!-- Card 1: Screenshot --}}
           {{!-- Card 1: Metric --}}


          {{!-- Card 2: Metric --}}
