      <div class="om-header">
        <h2 class="om-heading">Teams</h2>
        <p class="om-description">Building alignment, improving efficiency and accelerating delivery.</p>
      </div>

      <div class="om-carousel">
        <div class="om-carousel-track">
          {{!-- Card 1: Text --}}
          {{!-- Card 2: Metric --}}
          <div class="om-card om-card-metric">
