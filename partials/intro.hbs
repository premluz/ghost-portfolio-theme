{{!--
  INTRO ANIMATION COMPONENT
  Sequential animation sequence before hero:
  1. "Hello, I'm Prem" word reveal, stay 2s, reverse
  2. "Welcome to" word reveal, stay 2s, reverse
  3. Hero headline falls from top with physics acceleration
--}}

<section id="intro" class="intro">
  <div class="intro-content">
    <!-- Phase 1: Greeting with word reveal -->
    <h2 class="intro-greeting" data-skipAnimation="true">
      <span>Hello,</span> <span>I'm</span> <span>Prem</span>
    </h2>

    <!-- Phase 2: Welcome message with word reveal -->
    <h2 class="intro-welcome" data-skipAnimation="true">
      <span>Welcome</span> <span>to</span>
    </h2>

    <!-- Phase 3: Hero headline falls in -->
    <h1 class="intro-headline" data-skipAnimation="true">
      {{#if @custom.hero_headline}}{{@custom.hero_headline}}{{else}}Technically fluent designer.{{/if}}
    </h1>
  </div>
</section>
