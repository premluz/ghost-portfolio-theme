<section class="about-section">
  <header class="about-header">
    <h2>Open-minded with a</h2>
    <p class="section-description">bright personality<br>and small ego.</p>
  </header>

  <div class="about-grid">
    {{#get "posts" filter="tag:about" limit="all" include="tags,authors,html"}}
      {{#foreach posts}}
        {{> about-card}}
      {{/foreach}}
    {{/get}}
  </div>
</section>
