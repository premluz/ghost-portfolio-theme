<section class="about-section" id="aboutme">
  <header class="about-header">
    <h2 class="brand h1">Open-minded with a</h2>
    <p class="section-description">bright personality and small ego.</p>
  </header>

  <div class="about-grid">
    {{#get "posts" filter="tag:about" limit="100" include="tags,authors,html"}}
      {{#foreach posts}}
        {{> about-card}}
      {{/foreach}}
    {{/get}}
    {{!-- Find all about posts link hidden for now --}}
