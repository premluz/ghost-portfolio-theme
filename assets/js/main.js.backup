// ═══════════════════════════════════════════════════════════════
// HEADING ANIMATION CONFIG
// Controls scroll-triggered heading animations (initHeadingAnimations).
// data-animate and data-blur attributes on individual elements override
// these defaults per-instance.
// ═══════════════════════════════════════════════════════════════
const HEADING_ANIM_CONFIG = {
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // BLUR EFFECT
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  defaultBlur: 8,  // Initial blur in pixels. HIGHER = blurrier start (0-20px range)
                   // 0 = no blur, 8 = moderate, 15+ = very blurry

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // ANIMATION TYPE DEFAULTS (per heading level)
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  defaults: {
    h1: 'letter',   // Letter-by-letter (slow, deliberate)
    h2: 'letter',   // Letter-by-letter
    h3: 'word',     // Word-by-word (faster)
    h4: 'fade',     // Simple fade (fastest)
    // Override per-instance: add data-animate="letter"|"word"|"fade" to any element
  },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // LETTER-BY-LETTER ANIMATION (h1, h2)
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  letter: {
    charDuration: 0.14,      // Duration PER CHARACTER in seconds
                             // 0.10 = faster (1.4s for 14 chars)
                             // 0.20 = slower (2.8s for 14 chars)
                             // Try: 0.10-0.12 for snappy, 0.16-0.20 for slow
    ease: 'power1.out',      // Easing function: smooth deceleration
                             // Try: power2.out (even smoother), power0.5.out (gentler)
    spreadMin: 0.10,         // Min stagger for long text (tighter spacing)
    spreadMax: 0.22,         // Max stagger for short text (wider spacing)
                             // Prevents single-word h1 from taking forever
    blurDuration: 0.7,       // How long blur clears (seconds) in parallel with letters
                             // Usually 60% of total animation time
  },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // WORD-BY-WORD ANIMATION (h3)
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  word: {
    duration: 0.25,          // Total animation time (seconds) for ALL words
                             // 0.40 = fast (snappy), 0.55 = natural, 0.80 = cinematic
    stagger: 0.015,           // Delay (seconds) between each word entering
                             // 0.04 = rapid stagger, 0.06 = natural, 0.12 = dramatic
    ease: 'cubic-bezier(0.16, 0.84, 0.44, 1)',  // Easing (bouncy/energetic)
                             // Try: power2.out (smooth), elastic.out (bouncy)
    yOffset: 0,              // No vertical offset; blur does the reveal work
  },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // FADE ANIMATION (h4+, fallback)
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  fade: {
    duration: 0.6,           // Fade duration (seconds)
                             // 0.4 = quick, 0.6 = natural, 1.0 = slow/cinematic
    ease: 'power2.out',      // Easing: smooth deceleration
  },

  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  // SCROLL TRIGGER (IntersectionObserver)
  // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  observer: {
    // THRESHOLD: What % of element must be visible to trigger animation?
    // 0.1  = top 10% visible (earliest trigger)
    // 0.25 = top 25% visible (medium)
    // 0.5  = halfway visible (late trigger)
    // HIGHER threshold = waits longer / LOWER = triggers earlier
    threshold: 0.25,

    // ROOTMARGIN: Distance to trigger before reaching element
    // Format: 'top right bottom left' (CSS margin style)
    // 0px 0px -120px 0px = trigger 120px BEFORE hitting element
    // NEGATIVE = earlier trigger (more buffer), POSITIVE = later trigger
    // -80px  = trigger 80px earlier (aggressive)
    // -120px = trigger 120px earlier (current, balanced)
    // -200px = trigger 200px earlier (very early)
    // 0px    = trigger at exact viewport edge (no buffer)
    rootMargin: '0px 0px -120px 0px',
  },
};

