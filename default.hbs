  <script>
    (function() {
      if (window.location.pathname !== '/') return;
      // Only pre-hide the nav for a genuine fresh landing/refresh, not an
      // in-site click (e.g. the logo) — page-transition.js navigates via
      // window.location.href (a real page load, not a client-side route),
      // so document.referrer reliably reflects where we came from. Same
      // check preloader.js uses for its own skip path (assets/js/preloader.js) —
      // keep both in sync if this logic changes. Replaces the old
      // localStorage 'preloader_seen' once-per-session flag.
      var cameFromSameSite = false;
      try {
        cameFromSameSite = !!document.referrer && new URL(document.referrer).origin === window.location.origin;
      } catch (e) {}
      if (!cameFromSameSite) {
        document.documentElement.classList.add('preloading');
      }
    })();
  </script>
  {{ghost_head}}
  <script>
    // HOMEPAGE LANDING PRE-HIDE — must run in the REAL <head>: an earlier
    // placement deep in <body> ran after the browser had already parsed
    // and painted the hero markup above it (seen as a one-frame flash
    // before the entrance). Here, no paint can precede it. Same-site
    // arrival detection mirrors preloader.js's cameFromSameSite;
    // page-transition.js's landing branch removes the class when it takes
    // over, and the timeout guarantees the page can never stay blank.
    (function () {
      try {
        if (document.referrer && new URL(document.referrer).origin === location.origin &&
            (location.pathname === '/' || location.pathname === '')) {
          document.documentElement.classList.add('landing-pending');
          // The page-level entrance owns the reveal on this load — inner
          // hero choreography (text stagger, image fade) must not stack a
          // second animation on top (read by scroll-scrub-anim initHero
          // and main.js's hero image entrance).
          window.__pageEntranceOwns = true;
          setTimeout(function () { document.documentElement.classList.remove('landing-pending'); }, 2500);
        }
      } catch (e) {}
    })();
  </script>
