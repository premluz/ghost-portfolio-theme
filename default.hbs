  </script>
  <script src="https://unpkg.com/three@0.160.0/build/three.min.js"></script>
  <script>
    // HERO PARTICLE OBJECT — the single switch. 'volatility' shows the
    // ground-plane lattice and the helix never forms in the hero;
    // 'helix' restores the original helix and the lattice doesn't mount.
    // Read by particle-morph.hbs, scroll-scrub-anim.js, volatility-surface.js.
    window.HERO_PARTICLE_MODE = 'volatility';
    window.__heroShape = () => window.HERO_PARTICLE_MODE === 'helix' ? 'helix' : 'volatility';

    // PARTICLE SCENARIOS — declarative section→behavior map. Every particle
    // scroll trigger routes through __particleApply(key, builtin, ms), so a
    // scenario overrides what any trigger does WITHOUT touching trigger code:
    //   ''       (or key absent) → the trigger's built-in shape
    //   'hide'                   → fade the whole particle layer out
    //   any shape name           → morph to that shape instead
    // Keys: hero, hero-exit, operating-model, helix-section, profile,
    //       profile-exit, stats, work-grid, work-cards, lab, testimonials,
    //       footer, footer-exit
    // Switch: edit PARTICLE_SCENARIO below, or at runtime:
    //   setParticleScenario('hero-footer')  (persists in localStorage, reloads)
    window.PARTICLE_SCENARIOS = {
      full: {},                       // current site behavior, untouched
      'hero-footer': {                // particles ONLY in hero + footer
        'hero-exit': 'hide',
        'operating-model': 'hide',
        'helix-section': 'hide',
        profile: 'hide', 'profile-exit': 'hide',
        stats: 'hide',
        'work-grid': 'hide', 'work-cards': 'hide',
        lab: 'hide',
        testimonials: 'hide',
        'footer-exit': 'hide',
        // hero + footer absent → their built-in shapes (volatility/helix, grid)
      },
    };
    window.PARTICLE_SCENARIO = localStorage.getItem('particle_scenario') || 'hero-footer';

    // SCRUB KILL-SWITCH — diagnostic + low-end escape hatch. Scrub-driven
    // ScrollTriggers update on the main-thread rAF ticker; on weak GPUs the
    // compositor keeps scrolling smooth while JS rAF starves, so scrubbed
    // animations freeze mid-scroll and snap when scrolling stops. This
    // disables every scrub trigger WITH REVERT (inline styles removed →
    // content falls back to its visible CSS state), leaving the page fully
    // readable, just static. Toggle from the console:
    //   setScrubEnabled(false)  → static page (persists, reloads)
    //   setScrubEnabled(true)   → animations back
    // PERF HUD — diagnostic overlay for slow-machine investigation.
    // Console: showPerfHUD() -> live rAF fps / scroll events per second /
    // worst frame gap, top-right corner. showPerfHUD(false) removes it.
    window.showPerfHUD = (on = true) => {
      let el = document.getElementById('perf-hud');
      if (!on) { if (el) el.remove(); if (window.__hudStop) window.__hudStop(); return; }
      if (el) return;
      el = document.createElement('div');
      el.id = 'perf-hud';
      el.style.cssText = 'position:fixed;top:8px;right:8px;z-index:99999;background:rgba(0,0,0,.8);color:#0f0;font:12px/1.5 monospace;padding:8px 10px;border-radius:6px;pointer-events:none;white-space:pre';
      document.body.appendChild(el);
      let frames = 0, scrolls = 0, last = performance.now(), worst = 0, run = true;
      const tick = (now) => { frames++; worst = Math.max(worst, now - last); last = now; if (run) requestAnimationFrame(tick); };
      requestAnimationFrame(tick);
      const onScroll = () => scrolls++;
      window.addEventListener('scroll', onScroll, { passive: true });
      const iv = setInterval(() => {
        el.textContent = 'rAF fps: ' + (frames * 2) + String.fromCharCode(10) + 'scroll ev/s: ' + (scrolls * 2) + String.fromCharCode(10) + 'worst frame: ' + Math.round(worst) + 'ms';
        frames = 0; scrolls = 0; worst = 0;
      }, 500);
      window.__hudStop = () => { run = false; clearInterval(iv); window.removeEventListener('scroll', onScroll); };
    };

    // GLOBAL ANIMATION KILL-SWITCH — supersets the scrub switch below.
    // Console: setAnimationsEnabled(false) → fully static site (persists):
    //   scrub triggers off (revert to visible CSS states), GSAP time-based
    //   tweens complete instantly (entrances land revealed), CSS
    //   transitions/keyframes zeroed, particle layer hidden with its render
    //   loop never started. setAnimationsEnabled(true) restores everything.
    window.setAnimationsEnabled = (on) => {
      if (on) { localStorage.removeItem('animations_off'); localStorage.removeItem('scrub_off'); }
      else { localStorage.setItem('animations_off', '1'); localStorage.setItem('scrub_off', '1'); }
      location.reload();
    };
    if (localStorage.getItem('animations_off')) {
      document.documentElement.classList.add('no-anim');
      window.__particleLayerHidden = true; // render loop gate — never draws a frame
      // gsap loads later; as soon as it exists, make every time-based tween
      // effectively instant (scrub tweens are progress-driven and are
      // handled by the scrub_off path instead)
      const tick = setInterval(() => {
        if (window.gsap) { gsap.globalTimeline.timeScale(1000); clearInterval(tick); }
      }, 50);
      setTimeout(() => clearInterval(tick), 10000);
    }

    window.setScrubEnabled = (on) => {
      if (on) localStorage.removeItem('scrub_off');
      else localStorage.setItem('scrub_off', '1');
      location.reload();
    };
    if (localStorage.getItem('scrub_off')) {
      window.addEventListener('load', () => setTimeout(() => {
        if (!window.ScrollTrigger) return;
        let n = 0;
        ScrollTrigger.getAll().forEach((st) => {
          if (st.vars && st.vars.scrub) { st.disable(true); n++; }
        });
        console.log('[scrub] disabled ' + n + ' scrubbed ScrollTriggers — setScrubEnabled(true) to restore');
      }, 1200), { once: true });
    }
    window.setParticleScenario = (name) => { localStorage.setItem('particle_scenario', name); location.reload(); };

    // NO-HERO PAGES (hero-footer scenario): scenario 'hide' entries only
    // take effect when a trigger fires — a page without the homepage's
    // sections would keep whatever state the layer initialized with.
    // NOTE: /work/, /about/, /contact/ and posts are ALSO excluded from
    // the particle system upstream (particle-morph.hbs isPostPageOrExcluded
    // hides the container entirely), so today this rule is belt-and-braces;
    // it matters for any FUTURE hero-less page that isn't in that list,
    // keeping the particles-only-on-hero-and-footer intent true there.
    if (window.PARTICLE_SCENARIO === 'hero-footer') {
      document.addEventListener('DOMContentLoaded', function () {
        if (!document.querySelector('.hero')) {
          window.__particleLayerHidden = true;
          var layer = document.getElementById('particle-morph-demo');
          if (layer) layer.style.opacity = '0';
        }
      });
    }

    // CURTAIN-RETURN GUARD: when page-transition.js is about to restore a
    // mid-page scroll position (post → close → back to source), the page
    // boots fresh and the particle entrance would otherwise flash/appear
    // before (or after) the scrollThrough() sweep settles the real state.
    // Pre-hide the layer and its render loop from the very first frame;
    // the sweep's own triggers (hero-exit / footer / …) then take
    // ownership on their first call. Keys are only read here — consuming
    // them is page-transition.js's job.
    try {
      var __crOrigin = JSON.parse(sessionStorage.getItem('postOrigin') || 'null');
      if (sessionStorage.getItem('curtainReturn') === '1' &&
          __crOrigin && typeof __crOrigin.scrollY === 'number' && __crOrigin.scrollY > 100) {
        window.__particleLayerHidden = true;
        document.documentElement.classList.add('curtain-restoring');
        // failsafe: never let the veil outlive the restore window
        setTimeout(function () { document.documentElement.classList.remove('curtain-restoring'); }, 8000);
      }
    } catch (e) {}

    window.__particleApply = function (system, key, builtinShape, duration) {
      // Global animation kill-switch is authoritative: no morphs, and never
      // clear the hidden flag (a show-path call here used to re-arm the
      // render loop even though the container was display:none).
      if (document.documentElement.classList.contains('no-anim')) return;
      // HERO GUARDS. (1) While the curtain-return veil is up, 'hero'
      // applications are ignored outright — the entrance morph fires at
      // scrollY 0 BEFORE the restore sweep starts, and letting it through
      // would show the layer only for the sweep to hide it again mid-fade
      // (the reported flash). Only sweep-driven triggers (hero-exit,
      // footer, …) may take ownership and drop the veil. (2) Independent
      // of the veil: a 'hero' apply landing when the page is well past the
      // top is stale (its trigger fires at <=8px) — never re-show mid-page.
      const veiled = document.documentElement.classList.contains('curtain-restoring');
      if (key === 'hero' && (veiled || window.scrollY > 150)) return;
      document.documentElement.classList.remove('curtain-restoring');
      const scen = window.PARTICLE_SCENARIOS[window.PARTICLE_SCENARIO] || {};
      const target = (scen[key] === undefined || scen[key] === '') ? builtinShape : scen[key];
      const layer = document.getElementById('particle-morph-demo');
      if (target === 'hide') {
        // Play the trigger's built-in morph (usually 'dispersed') UNDER the
        // fade, so hiding reads as "particles disperse away" rather than a
        // frozen shape dimming out — but only if the layer is currently
        // visible (morphing an already-hidden layer is wasted work).
        if (!window.__particleLayerHidden && system && typeof system.morphTo === 'function' && builtinShape) {
          system.morphTo(builtinShape, duration);
        }
        if (layer) { layer.style.transition = 'opacity 0.6s ease'; layer.style.opacity = '0'; }
        // Pause the render loop only AFTER the fade finishes — pausing
        // immediately would freeze the first hidden frame and the disperse
        // morph above would never be seen.
        clearTimeout(window.__particleHideTimer);
        window.__particleHideTimer = setTimeout(() => { window.__particleLayerHidden = true; }, 700);
        return;
      }
      clearTimeout(window.__particleHideTimer);
      window.__particleLayerHidden = false;
      if (layer && layer.style.opacity === '0') { layer.style.transition = 'opacity 0.6s ease'; layer.style.opacity = '1'; }
      if (system && typeof system.morphTo === 'function' && target) system.morphTo(target, duration);
    };
  </script>
