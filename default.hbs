  <!-- Console cleanup: suppress verbose module logs. Installed this early
       (before three.js/preloader/intro/gradient-layer/etc. load) so no
       script gets a chance to log before the gate is active — moving this
       later (it used to sit near the end of <body>) left ~50 early
       top-level logs from those scripts ungated regardless of DEBUG_SCROLL. -->
  <script>
  (function() {
    const originalLog = console.log;
    const originalWarn = console.warn;
    const originalError = console.error;
    const suppressPatterns = [
      /\[gradient-layer\]/i,
      /\[gradient-animation-loop\]/i,
      /\[testimonial-modal\]/i,
      /\[post-and-cards\]/i,
      /\[ShapeLoader\] Failed to load GLB/i,
      /\[intro\]/i,
      /assets\/glb\//i,  // Suppress all GLB 404 errors
      /Missing elements/i
    ];

    const shouldSuppress = (msg) => {
      const text = msg?.toString?.() || '';
      return suppressPatterns.some(pattern => pattern.test(text));
    };

    // Silent by default — set window.DEBUG_SCROLL = true (devtools/URL) to
    // see the 300+ scroll/particle/morph logs this theme normally emits.
    // suppressPatterns above stays applied even in debug mode — those are
    // separately-known noise (GLB 404s, gradient-layer spam), not wanted
    // either way. console.error is never gated by the flag, only by
    // suppressPatterns, matching debug.js's debugError() "always log
    // errors, even in production" behavior.
    console.log = function(...args) {
      if (!window.DEBUG_SCROLL) return;
      if (shouldSuppress(args[0])) return;
      originalLog.apply(console, args);
    };

    console.warn = function(...args) {
      if (!window.DEBUG_SCROLL) return;
      if (shouldSuppress(args[0])) return;
      originalWarn.apply(console, args);
    };

    console.error = function(...args) {
      if (!shouldSuppress(args[0])) {
        originalError.apply(console, args);
      }
    };
  })();
  </script>

  <!-- Loaded this early so window.resizeManager exists before any later
