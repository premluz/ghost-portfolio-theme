<!DOCTYPE html>
<html lang="en">
<head>
  <meta name="color-scheme" content="dark light">
  <meta name="theme-color" content="#1d1e1f">
  <meta name="robots" content="noindex, nofollow">
  <script>
    // Apply saved theme and set root background immediately to prevent white flash
    // Runs before any CSS or external resource can trigger a paint.
    // ⚠ REGRESSION MAGNET: an old copy of this block was pasted back once
    // (stale hexes + body background rules) and broke the profile palette
    // shift in light mode. If you edit this block, keep three invariants:
    //   1. Hexes here are manual copies of tokens.css's --theme-light-bg /
    //      --theme-dark-bg — update together (see COMMON_ISSUES.md).
    //   2. NEVER set a body background (inline or in the <style> below):
    //      body must stay transparent so the fixed #page-backdrop can paint
    //      the shiftable page background (CSS paint order puts it below
    //      in-flow block backgrounds — an opaque body hides it silently).
    //   3. window.__THEME_BG_COLORS__ is read by theme.js — keep exporting it.
    (function() {
      // Single source of truth for the anti-flash hex values — exposed on
      // window so theme.js's setTheme() reads these instead of keeping its
      // own copy (they'd previously drift independently). The <style>
      // fallback below can't reference this (CSS, no JS) and stays a
      // necessarily-separate hardcoded copy — keep it in sync manually.
      var THEME_BG = { light: '#FAFAF8', dim: '#1d1e1f', dark: '#1d1e1f' };
      window.__THEME_BG_COLORS__ = THEME_BG;

      var saved = localStorage.getItem('theme-preference');
      var defaultTheme = '{{@custom.color_scheme}}';
      var theme = saved !== null ? saved : defaultTheme;

      if (theme === 'auto' || theme === 'dim') {
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        theme = prefersDark ? 'dark' : 'light';
      }

      var bg = THEME_BG[theme] || THEME_BG.dark;
      var colorScheme = (theme === 'light') ? 'light' : 'dark';

      // Set inline style on html immediately (before CSS loads) to prevent
      // white flash. html ONLY — see invariant 2 above re: body.
      document.documentElement.style.backgroundColor = bg;
      document.documentElement.style.colorScheme = colorScheme;

      // Also set data-theme for CSS selectors
      if (theme === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      } else if (theme === 'dim') {
        document.documentElement.setAttribute('data-theme', 'dim');
      } else {
        document.documentElement.removeAttribute('data-theme');
      }

      // Keep theme-color and color-scheme meta tags in sync (browser paints before CSS)
      var metaTheme = document.querySelector('meta[name="theme-color"]');
      if (metaTheme) metaTheme.setAttribute('content', bg);
      var metaScheme = document.querySelector('meta[name="color-scheme"]');
      if (metaScheme) metaScheme.setAttribute('content', colorScheme);
    })();
  </script>
  <script src="{{asset "js/device-capability.js"}}?v={{@site.updated_at}}"></script>
  <style>
    /* Defensive anti-flash fallback: ROOT background only, before CSS loads.
       Hexes are manual copies of tokens.css --theme-*-bg — keep in sync.
       NO body rules here ON PURPOSE (invariant 2 in the script above):
       body stays transparent so the fixed #page-backdrop can carry the
       scroll-driven palette shift. The html background covers pre-CSS flash. */
    html { background-color: #1d1e1f; }
    html[data-theme='light'] { background-color: #FAFAF8; }
    html[data-theme='dim'] { background-color: #1d1e1f; }

    /* Hide preloader immediately — no blink on page load */
    #preloader { display: none !important; }

    /* Navigation visible immediately — no blink, no animation */
    .gh-navigation {
      animation: none !important;
      opacity: 1 !important;
      visibility: visible !important;
      pointer-events: auto !important;
    }
  </style>
