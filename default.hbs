  <script>
    (function() {
      if (window.location.pathname !== '/') return;
      // Only pre-hide the nav for a genuine fresh landing/refresh, not an
      // in-site click (e.g. the logo) — page-transition.js navigates via
      // window.location.href (a real page load, not a client-side route),
      // so document.referrer reliably reflects where we came from. Same
      // check preloader.js uses for its own skip path (assets/js/preloader.js) —
      // keep both in sync if this logic changes. Replaces the old
      // localStorage 'preloader_seen' once-per-session flag.
      var cameFromSameSite = false;
      try {
        cameFromSameSite = !!document.referrer && new URL(document.referrer).origin === window.location.origin;
      } catch (e) {}
      if (!cameFromSameSite) {
        document.documentElement.classList.add('preloading');
      }
    })();
  </script>
