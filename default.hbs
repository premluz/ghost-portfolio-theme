              data-members-email
            >
            <button type="submit" class="button footer-button" aria-label="Subscribe">
              Subscribe
              <img src="{{asset "icons/arrow-right.svg"}}" alt="Subscribe" class="footer-button-icon">
            </button>
            <p class="footer-form-message" data-members-error></p>
