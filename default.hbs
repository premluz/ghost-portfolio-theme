<!DOCTYPE html>
<html lang="en" data-theme="{{@custom.color_scheme}}" data-type-size="{{@custom.type_size}}" data-type-space="{{@custom.type_spacing}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{meta_title}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&display=swap">
  {{ghost_head}}
  <link rel="stylesheet" href="{{asset "css/main.css"}}">
  <style>
    /*
     * Accent color injection from Ghost admin settings.
     * Only --color-primary is set here. All other semantic tokens
     * (--color-link, --color-link-hover, --color-secondary) are
     * derived from --color-primary inside tokens.css to keep one
     * source of truth and avoid cascade conflicts.
     */
    :root {
      {{#if @site.accent_color}}
        --color-primary: {{@site.accent_color}};
      {{/if}}
      {{#if @site.icon}}
        --publication-icon: url('{{@site.icon}}');
      {{/if}}
    }

    :root[data-theme='light'] {
      {{#if @site.accent_color}}
        --color-primary: {{@site.accent_color}};
      {{else}}
        --color-primary: #60A26B;
      {{/if}}
    }

    :root[data-theme='dim'] {
      {{#if @site.accent_color}}
        --color-primary: {{@site.accent_color}};
      {{/if}}
    }
  </style>
  <script>
    // Apply saved theme immediately to prevent flash of wrong theme
    (function() {
      var theme = localStorage.getItem('theme-preference') || '{{@custom.color_scheme}}';
      if (theme) {
        document.documentElement.setAttribute('data-theme', theme);
      }
    })();
  </script>
</head>
<body class="{{body_class}}" data-page-width="{{@custom.page_width}}" data-card-style="{{@custom.card_style}}" data-typography="{{@custom.typography_style}}">
  {{#if @custom.show_scroll_progress}}<div class="scroll-progress"></div>{{/if}}

  {{> navigation}}

  <main>
    {{{body}}}
  </main>

  <footer class="gh-footer" data-footer-width="{{@custom.footer_width}}">
    <div class="footer-bg">
      <div class="footer-content">
        <div class="footer-signup-section">
          <h2 class="footer-title">{{@site.title}}</h2>
          <p class="footer-description">Let's work together.</p>
                    <button type="submit" class="button footer-button" aria-label="Subscribe">
              Contact me
              <img src="{{asset "icons/arrow-right.svg"}}" alt="Subscribe" class="footer-button-icon">
            </button>
          <!-- <form class="footer-form" data-members-form>
