{{!< default}}
<article class="page">
  {{#if @page.show_title_and_feature_image}}
    <header class="page-header">
      <div class="container">
        <h1 class="page-title">About {{@site.title}}</h1>
      </div>
    </header>
  {{/if}}

  <div class="page-content container">
    <p>Welcome to {{@site.title}}. {{@site.description}}</p>
    <p>This is a bold, typographic Ghost theme designed for independent creators, writers, and thinkers who want to share their ideas with the world.</p>
  </div>
</article>
